# ========== 开发环境配置 (dev) ==========

# 运行环境
APP_ENV=dev

# TCP 监听配置
GATE_TCP_BIND=0.0.0.0
GATE_TCP_PORT=7888

# HTTP 监控运维端口
GATE_HTTP_BIND=0.0.0.0
GATE_HTTP_PORT=9090

# 网关节点ID（集群内唯一）
GATE_NODE_ID=1
GATE_NODE_NAME=gate-dev-01

# Redis 集群配置
REDIS_URL=redis://127.0.0.1:6379
REDIS_CLUSTER=false
REDIS_POOL_SIZE=8

# gRPC 逻辑服地址（多个用逗号分隔）
GRPC_LOGIC_ENDPOINTS=grpc://127.0.0.1:50051

# Tokio 运行时线程数
TOKIO_WORKER_THREADS=4

# 日志级别
LOG_LEVEL=info
LOG_FORMAT=pretty

# 限流配置
RATE_LIMIT_PLAYER_PER_SEC=1000
RATE_LIMIT_PLAYER_BATTLE_PER_SEC=2000
RATE_LIMIT_GLOBAL_PER_SEC=200000

# IP连接频率限制（压测时调大，默认20/5s）
IP_CONNECT_MAX=10000

# 会话配置
SESSION_HEARTBEAT_TIMEOUT_SECS=45
SESSION_HEARTBEAT_CHECK_INTERVAL_SECS=10

# 协议配置
PROTOCOL_MAX_PACKET_SIZE=8192
PROTOCOL_PACKET_MAGIC=0x4D4D4F47

# 加密密钥（开发环境，32字节=64 hex字符，AES-256-GCM）
AES_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
AES_NONCE=0011223344556677

# 小包合并窗口（毫秒）
PACKET_MERGE_WINDOW_MS=16
