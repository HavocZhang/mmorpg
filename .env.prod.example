# ========== 生产环境配置 (prod) ==========
# 此文件为模板，实际部署时请替换敏感字段（密钥、密码等）
# 建议通过 Kubernetes Secret 或 Docker Secret 注入敏感配置

# 运行环境
APP_ENV=prod

# TCP 监听配置
GATE_TCP_BIND=0.0.0.0
GATE_TCP_PORT=7888

# HTTP 监控运维端口（生产环境建议仅内网开放或加 IP 白名单）
GATE_HTTP_BIND=0.0.0.0
GATE_HTTP_PORT=9090

# 网关节点ID（集群内唯一，多节点部署时每节点不同）
GATE_NODE_ID=1
GATE_NODE_NAME=gate-prod-01

# Redis 集群配置（生产环境建议使用 Redis Cluster 或 Redis Sentinel）
REDIS_URL=redis://redis-master:6379
REDIS_CLUSTER=true
REDIS_POOL_SIZE=16

# gRPC 逻辑服地址（多个用逗号分隔，生产环境至少 2 个做容灾）
GRPC_LOGIC_ENDPOINTS=grpc://logic-server-1:50051,grpc://logic-server-2:50051

# Tokio 运行时线程数（建议等于 CPU 核心数）
TOKIO_WORKER_THREADS=4

# 日志级别（生产环境用 info 或 warn，禁止 debug/trace）
LOG_LEVEL=info
LOG_FORMAT=json

# 限流配置（生产环境安全值）
RATE_LIMIT_PLAYER_PER_SEC=30
RATE_LIMIT_PLAYER_BATTLE_PER_SEC=80
RATE_LIMIT_GLOBAL_PER_SEC=80000

# IP连接频率限制（防 CC 攻击，5秒内同IP最多20次连接）
IP_CONNECT_MAX=20

# 会话配置
SESSION_HEARTBEAT_TIMEOUT_SECS=45
SESSION_HEARTBEAT_CHECK_INTERVAL_SECS=10

# 协议配置
PROTOCOL_MAX_PACKET_SIZE=8192
PROTOCOL_PACKET_MAGIC=0x4D4D4F47

# 加密密钥（生产环境必须替换为随机密钥，32字节=64 hex字符）
# 生成方法: openssl rand -hex 32
AES_KEY=CHANGE_ME_TO_RANDOM_32_BYTE_HEX_KEY_REQUIRED_HERE!!
AES_NONCE=CHANGE_ME!

# 小包合并窗口（毫秒）
PACKET_MERGE_WINDOW_MS=16
